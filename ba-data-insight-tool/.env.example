# Treasury Tower MySQL connection.
# Preferred form:
TREASURY_DATABASE_URL=mysql+pymysql://ba_user:ba_password@localhost:3306/treasury

# Optional fallback name if your deployment already injects DATABASE_URL.
# DATABASE_URL=mysql+pymysql://ba_user:ba_password@localhost:3306/treasury

# Optional separated variables. Used only when TREASURY_DATABASE_URL/DATABASE_URL are not set.
TREASURY_DB_HOST=localhost
TREASURY_DB_PORT=3306
TREASURY_DB_USER=ba_user
TREASURY_DB_PASSWORD=ba_password
TREASURY_DB_NAME=treasury
